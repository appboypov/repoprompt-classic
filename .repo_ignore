# see them when they are present in a workspace.
!/docs/
!/docs/**
!/prompt-exports/
!/prompt-exports/**
!/RepoPrompt/Docs/
!/RepoPrompt/Docs/**
!/RepoPrompt/prompt-exports/
!/RepoPrompt/prompt-exports/**
